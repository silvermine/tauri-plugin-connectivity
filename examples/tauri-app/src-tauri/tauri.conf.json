{
   "$schema": "https://schema.tauri.app/config/2",
   "productName": "connectivity-example",
   "version": "0.1.0",
   "identifier": "com.silvermine.connectivity-example",
   "build": {
      "frontendDist": "../dist",
      "devUrl": "http://localhost:1420",
      "beforeDevCommand": "npm run vite -- --host",
      "beforeBuildCommand": "npm run build"
   },
   "app": {
      "windows": [
         {
            "title": "Connectivity Example",
            "width": 900,
            "height": 700
         }
      ],
      "security": {
         "csp": null
      }
   },
   "bundle": {
      "active": true,
      "targets": "all",
      "icon": [
         "icons/32x32.png",
         "icons/128x128.png",
         "icons/128x128@2x.png",
         "icons/icon.icns",
         "icons/icon.ico"
      ]
   }
}
